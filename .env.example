# Remote target (Tailscale host running n8n / Postgres / RSSHub / Next.js)
REMOTE_USER=your-ssh-user
REMOTE_HOST=your-server-host
REMOTE_DIR=/path/to/news
REMOTE_USER_HOME=/path/to/home

# Local dev workstation Tailscale IP — used as outbound HTTP proxy
# (must run a proxy listening on this IP:port, e.g. Surge / Clash on the workstation)
MBP_PROXY=http://your-proxy-host:port

# Postgres (on remote — local trust auth, no password needed)
PGUSER=your-postgres-user
PGDATABASE=news
PGHOST=127.0.0.1
PGPORT=5432
PGPASSWORD=
PGSSL=disable

# Service ports (on remote)
N8N_PORT=5678
N8N_SECURE_COOKIE=false
RSSHUB_PORT=1200
WEB_PORT=3000

# Web env (rendered into web/.env.production by deploy script)
N8N_WEBHOOK_BASE=https://n8n-api.wenmsg.fun
NEWS_API_SECRET=

# RSSHub Twitter auth — auth_token cookie from x.com (rotate periodically)
TWITTER_AUTH_TOKEN=

# OpenAI-compatible LLM API for enrichment and topic rebuilding.
AI_API_KEY=
AI_MODEL=deepseek-v4-flash
AI_API_URL=https://api.deepseek.com/chat/completions
AI_THINKING=disabled

# Legacy compatibility only. Prefer AI_* above for new deployments.
MOONSHOT_API_KEY=
MOONSHOT_MODEL=
MOONSHOT_API_URL=
