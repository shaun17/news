# Remote target (Tailscale host running n8n / Postgres / RSSHub / Next.js)
REMOTE_USER=coco
REMOTE_HOST=100.104.136.117
REMOTE_DIR=/Users/coco/code/news
REMOTE_USER_HOME=/Users/coco

# Local dev workstation Tailscale IP — used as outbound HTTP proxy
# (must run a proxy listening on this IP:port, e.g. Surge / Clash on the workstation)
MBP_PROXY=http://100.126.75.65:6152

# Postgres (on remote — local trust auth, no password needed)
PGUSER=coco
PGDATABASE=news
PGHOST=127.0.0.1
PGPORT=5432

# Service ports (on remote)
N8N_PORT=5678
RSSHUB_PORT=1200
WEB_PORT=3000

# Web env (rendered into web/.env.production by deploy script)
N8N_WEBHOOK_BASE=http://127.0.0.1:5678

# RSSHub Twitter auth — auth_token cookie from x.com (rotate periodically)
TWITTER_AUTH_TOKEN=

# Kimi (Moonshot) API for enrich.py — https://platform.moonshot.cn
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2-0905-preview
MOONSHOT_API_URL=https://api.moonshot.cn/v1/chat/completions
